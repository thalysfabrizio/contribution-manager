generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// === NextAuth models ===

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// === App models ===

model User {
  id              String           @id @default(cuid())
  name            String?
  email           String           @unique
  emailVerified   DateTime?
  image           String?
  consentAt       DateTime?
  consentVersion  String?
  accounts        Account[]
  sessions        Session[]
  ownedCampaigns  Campaign[]       @relation("owned")
  memberships     CampaignMember[]
  auditLogs       AuditLog[]
  createdAt       DateTime         @default(now())
}

model Campaign {
  id              String           @id @default(cuid())
  name            String
  description     String?
  pixKey          String
  monthlyValue    Int              // Centavos (2000 = R$20,00)
  startMonth      DateTime
  endMonth        DateTime
  paymentDayStart Int              @default(10)
  paymentDayEnd   Int              @default(15)
  templates       Json?
  // Branding / personalização
  orgName         String?          // Nome da organização (exibido no header)
  logoUrl         String?          // URL do logo
  bannerUrl       String?          // URL do banner/capa
  accentColor     String?          // Cor primária (ex: "#8b5cf6")
  messageSignature String?         // Assinatura para mensagens WhatsApp
  owner           User             @relation("owned", fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId         String
  members         CampaignMember[]
  participants    Participant[]
  auditLogs       AuditLog[]
  createdAt       DateTime         @default(now())
}

model CampaignMember {
  id         String       @id @default(cuid())
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  campaign   Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId String
  role       CampaignRole @default(MEMBER)
  joinedAt   DateTime     @default(now())

  @@unique([userId, campaignId])
}

enum CampaignRole {
  OWNER
  MEMBER
}

model Person {
  id           String        @id @default(cuid())
  name         String
  phone        String        @unique
  participants Participant[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Participant {
  id         String    @id @default(cuid())
  person     Person    @relation(fields: [personId], references: [id])
  personId   String
  campaign   Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId String
  payments   Payment[]
  joinedAt   DateTime  @default(now())

  @@unique([personId, campaignId])
  @@index([campaignId])
}

model Payment {
  id            String        @id @default(cuid())
  month         DateTime
  status        PaymentStatus
  participant   Participant   @relation(fields: [participantId], references: [id], onDelete: Cascade)
  participantId String
  paidAt        DateTime?
  createdAt     DateTime      @default(now())

  @@unique([participantId, month])
}

enum PaymentStatus {
  PENDING
  PAID_PIX
  PAID_CASH
  LATE
}

model AuditLog {
  id             String      @id @default(cuid())
  action         AuditAction
  entity         String
  entityId       String?
  details        Json
  user           User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId         String?
  actorEmailHash String?
  campaign       Campaign    @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  campaignId     String
  createdAt      DateTime    @default(now())

  @@index([campaignId, createdAt])
  @@index([entityId, entity])
}

enum AuditAction {
  PAYMENT_UPDATED
  PARTICIPANT_ADDED
  PARTICIPANT_EDITED
  PARTICIPANT_REMOVED
  MESSAGE_SENT
  CAMPAIGN_CREATED
  CAMPAIGN_EDITED
  MEMBER_INVITED
  MEMBER_REMOVED
}

model RateLimit {
  id          String   @id @default(cuid())
  key         String   @unique
  count       Int      @default(1)
  windowStart DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([windowStart])
}
