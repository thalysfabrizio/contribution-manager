{
  "name": "contribution-manager",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:seed": "tsx prisma/seed.ts",
    "db:migrate-json": "tsx prisma/migrate-json.ts",
    "cleanup:audit-logs": "tsx scripts/cleanup-audit-logs.ts",
    "db:backup": "bash scripts/db-backup.sh",
    "db:restore": "bash scripts/db-restore.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:migrate": "tsx scripts/with-e2e-db.ts npx prisma migrate deploy",
    "e2e:build": "tsx scripts/with-e2e-db.ts npx next build",
    "e2e:serve": "tsx scripts/with-e2e-db.ts npx next start -p 3100"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@sentry/nextjs": "^10.49.0",
    "lucide-react": "^1.8.0",
    "next": "^16.2.4",
    "next-auth": "^5.0.0-beta.30",
    "pg": "^8.20.0",
    "prisma": "^7.7.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.10.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.19.17",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.4",
    "dotenv": "^17.4.1",
    "eslint": "^9",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
