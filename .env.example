# ============================================================
# Contribution Manager — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais.
# Todas as variáveis abaixo são obrigatórias — o app valida na
# inicialização (src/lib/env.ts) e falha com erro explícito se
# algo estiver ausente ou inválido.
# ============================================================

# --- Banco de dados (PostgreSQL) ---
# Dev local (docker compose up -d):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/contribution_manager?schema=public"
# Produção: depende do alvo de deploy escolhido (postgres no compose da VPS,
# managed Postgres, etc). Use ?sslmode=require quando estiver fora da rede privada.

# Banco dedicado para testes E2E. PRECISA ser diferente de DATABASE_URL — o
# globalSetup do Playwright apaga todos os usuários a cada rodada.
E2E_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/contribution_manager_e2e?schema=public"

# --- NextAuth ---
# URL completa da aplicação (sem barra no final).
NEXTAUTH_URL="http://localhost:3000"

# Segredo usado para assinar sessões JWT. Mínimo 32 caracteres.
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=""

# --- Google OAuth ---
# Crie um OAuth Client em https://console.cloud.google.com/apis/credentials
# Redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Resend (magic link de email) ---
# Obtenha a chave em https://resend.com/api-keys (começa com "re_")
RESEND_API_KEY=""

# Endereço "from" dos emails de magic link.
# Precisa ser um domínio verificado no Resend em produção.
EMAIL_FROM="noreply@seudominio.com"

# Controla a exibição do login por magic link na tela de login.
# Deixe "true" em dev; em prod mantenha ausente/"false" enquanto o
# domínio do EMAIL_FROM não estiver verificado no Resend (o sandbox
# "onboarding@resend.dev" só entrega para o dono da conta).
NEXT_PUBLIC_AUTH_EMAIL_ENABLED="true"

# --- Sentry (observabilidade, opcional em dev) ---
# Sem SENTRY_DSN o SDK fica inativo — o app continua funcionando normalmente.
# Obtenha DSN em https://sentry.io/settings/projects/<project>/keys/
SENTRY_DSN=""
# O NEXT_PUBLIC_SENTRY_DSN é exposto ao browser; em produção use o mesmo valor
# do SENTRY_DSN (ou um DSN separado só para client). Deixe vazio para desabilitar
# captura no browser.
NEXT_PUBLIC_SENTRY_DSN=""
# Nome do ambiente que aparecerá no dashboard (ex.: production, staging).
SENTRY_ENVIRONMENT=""
# Para upload de source maps no build (CI/produção):
# Crie um token em https://sentry.io/settings/account/api/auth-tokens/
# com escopo project:releases. Sem o token o build pula o upload.
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""
